# =============================================================================
# ARK / QuantumIndustries — environment template
# =============================================================================
# Copy this file to `.env` in the repo root (`.env` is gitignored) and paste your
# values after each `=`. Vite loads `.env`, `.env.local`, etc. for local dev.
#
# On Vercel: Project → Settings → Environment Variables. Use the same names.
# For Discovery + contact APIs to work in production, add RESEND_API_KEY,
# CONTACT_FROM_EMAIL, and CONTACT_NOTIFY_EMAIL for the Production environment
# (and redeploy). If any are missing, /api/consultation and /api/consultation-audio
# return 503. Check Vercel → Logs for "[consultation-audio] Email not configured"
# to see which flags are false.
# Do NOT commit real keys. `VITE_*` vars are exposed to the browser; never put
# secrets in a `VITE_` variable.
# =============================================================================


# -----------------------------------------------------------------------------
# OPENAI (required for these features to work)
# -----------------------------------------------------------------------------
# Get: https://platform.openai.com/api-keys
# Used by: site chat assistant (/api/chat), voice Discovery form path (Whisper transcription)
#          (/api/consultation-audio → Whisper). Typed-only consultation does not
#          call OpenAI.
OPENAI_API_KEY=


# -----------------------------------------------------------------------------
# RESEND + EMAIL IDENTITY (required for contact + typed and voice Discovery form paths)
# -----------------------------------------------------------------------------
# Get API key: https://resend.com/api-keys
# Resend shows the full secret only once when you create the key—the dashboard
# “re_abc…” prefix is not enough. After editing .env, restart `npm run dev`.
# Verify your sending domain in Resend → Domains, add DNS records, then use a
# From address on that domain (e.g. hello@arksolutions.ai).
RESEND_API_KEY=

# Shown as the sender on outbound mail (team + optional user confirmation).
# Example: Ark Solutions <hello@yourdomain.com>
CONTACT_FROM_EMAIL=

# Inbox where you want new submissions (contact + Discovery forms).
CONTACT_NOTIFY_EMAIL=


# -----------------------------------------------------------------------------
# SITE URL (optional but recommended for production emails)
# -----------------------------------------------------------------------------
# Canonical public URL, no trailing slash. Used in email footers/links when set.
# Defaults in code to https://arksolutions.ai if unset.
SITE_PUBLIC_URL=


# -----------------------------------------------------------------------------
# OPTIONAL — override API URLs (defaults are same-origin /api/...)
# -----------------------------------------------------------------------------
# VITE_CHAT_API_URL=
# VITE_CONTACT_API_URL=
# VITE_CONSULTATION_API_URL=
# VITE_CONSULTATION_AUDIO_API_URL=


# -----------------------------------------------------------------------------
# OPTIONAL — Cal.com booking embed
# -----------------------------------------------------------------------------
# Full HTTPS URL to your Cal event. If unset, the app uses its built-in default.
# VITE_CAL_BOOKING_URL=
