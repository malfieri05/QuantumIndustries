# Required for the chat assistant (Vercel: Project → Environment Variables).
#
# Local dev: put your key in the root `.env` file (see repo root) or use `.env.local`
# (also gitignored). Vite loads both.
OPENAI_API_KEY=

# Optional: override chat API URL (defaults to /api/chat on the same origin).
# VITE_CHAT_API_URL=

# Contact form (Resend). Add quantumindustries.ai in Resend → Domains, set DNS records, then use a From on that domain.
# Vercel: set these under Project → Environment Variables (not VITE_* — server only).
RESEND_API_KEY=
# e.g. "Ark Solutions <hello@yourdomain.com>"
CONTACT_FROM_EMAIL=
# Where new submissions are delivered (your inbox).
CONTACT_NOTIFY_EMAIL=

# Optional: public site URL for email assets and links (defaults to https://quantumindustries.ai).
# SITE_PUBLIC_URL=

# Optional: override contact API URL in the browser (defaults to /api/contact).
# VITE_CONTACT_API_URL=
